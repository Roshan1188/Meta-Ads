# ---------------------------------------------------------------------------
# AutoAds AI — copy to `.env` and fill in. Never commit `.env`.
# Phase 0 only needs DATABASE_URL + NEXTAUTH_SECRET. Everything else can stay
# blank; the app degrades gracefully and tells you what's missing.
# ---------------------------------------------------------------------------

# Core --------------------------------------------------------------- Phase 0
# Postgres. Local docker, or a free Neon/Supabase branch.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autoads?schema=public"
# Generate with: npx auth secret   (or: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
APP_NAME=AutoAds AI

# AI ----------------------------------------------------------------- Phase 1
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# https://replicate.com/account/api-tokens  (image generation)
REPLICATE_API_TOKEN=
# https://shotstack.io  (video — optional; the video step is skipped without it)
SHOTSTACK_API_KEY=
# Image/video calls cost money per request. Generations per user per day.
GENERATION_DAILY_LIMIT=10

# Meta --------------------------------------------------------------- Phase 2
# https://developers.facebook.com/apps → your app → Settings → Basic
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0
META_REDIRECT_URI=http://localhost:3000/api/meta/callback

# Jobs --------------------------------------------------------------- Phase 3
# https://app.inngest.com  (not needed for `npx inngest-cli dev` locally)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Billing ------------------------------------------------------------ Phase 4
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook → https://dashboard.razorpay.com/app/webhooks
# Point it at {NEXTAUTH_URL}/api/webhooks/razorpay and subscribe to the
# subscription.* events. This — not the checkout redirect — is what grants a plan.
RAZORPAY_WEBHOOK_SECRET=
# Plans are created in the Razorpay dashboard; paste their ids here.
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_GROWTH=
RAZORPAY_PLAN_AGENCY=

# Notifications ------------------------------------------------------ Phase 4
# https://resend.com/api-keys — used for reports, team invites, and spend alerts.
RESEND_API_KEY=
REPORT_FROM_EMAIL=reports@yourdomain.com
# WhatsApp Cloud API. Scheduled reports are business-initiated, so they MUST use a
# pre-approved template — a plain text body is silently rejected by Meta.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_REPORT_TEMPLATE=ad_performance_report
