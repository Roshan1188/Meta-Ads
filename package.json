{
  "name": "autoads-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:rules": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/check-rules.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "inngest:dev": "npx inngest-cli@latest dev",
    "check:permissions": "cross-env NODE_OPTIONS=--conditions=react-server tsx scripts/check-permissions.ts",
    "check": "npm run typecheck && npm run check:rules && npm run check:permissions"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.6.0",
    "@google/genai": "^2.11.0",
    "@prisma/client": "6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "inngest": "^4.12.1",
    "lucide-react": "^1.24.0",
    "next": "15.5.20",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
